{
  "name": "obsidian-image-viewer",
  "version": "1.0.0",
  "description": "A powerful image viewer plugin for Obsidian, inspired by PicView",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "node deploy.mjs",
    "build-deploy": "npm run build && npm run deploy",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "release": "node release.mjs"
  },
  "keywords": [
    "obsidian",
    "image",
    "viewer",
    "gallery"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0"
  }
}
