{
  "name": "image-viewer",
  "version": "1.0.0",
  "description": "A powerful image viewer with gallery view, zoom, slideshow and more.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "npm run build && node deploy.mjs",
    "release": "node release.mjs"
  },
  "keywords": [
    "obsidian",
    "image",
    "viewer",
    "gallery"
  ],
  "author": "lizhifeng",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0"
  }
}